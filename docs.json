{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "StageSnap",
  "description": "AI-powered real estate image and video staging",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "openapi": "openapi.yaml"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@stagesnap.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to app",
      "href": "https://stagesnap.ai"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "StageSnap app",
          "icon": "house",
          "href": "https://stagesnap.ai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/stage-a-room",
              "guides/generate-a-video",
              "guides/webhooks",
              "guides/postcard-campaigns"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Images",
            "pages": [
              "api-reference/stage",
              "api-reference/flyer"
            ]
          },
          {
            "group": "Video",
            "pages": [
              "api-reference/video",
              "api-reference/status"
            ]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://stagesnap.ai"
    }
  }
}
